    var shop=[], total=0; order.forEach(function(fl){ var pr=prod(fl); var b=Math.max(1,Math.ceil(demand[fl].bu-1e-9)); total+=b*pr.bunch; shop.push(b+' bunch '+fl+' ($'+Math.round(b*pr.bunch)+')'); });
    return { pieces:lines, shop:shop, total:total };
