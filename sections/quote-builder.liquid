  function openGallery(role,idx,piece){
    galTarget={role:role, idx:idx, piece:piece||null};
    ensureGal();
    document.getElementById('vgalTitle').textContent='Choose your '+ROLE_NAME[role].toLowerCase();
    document.getElementById('vgalSearch').value='';
    renderGalTiles('');
    showGal();
  }
  function showGal(){ var g=document.getElementById('bcfVgal'); g.classList.add('on'); var grid=document.getElementById('vgalGrid'); if(grid) grid.scrollTop=0; }
  function openGalleryAdd(piece){ galTarget={piece:piece, add:true}; galFilter='all'; ensureGal(); document.getElementById('vgalTitle').textContent='Add a flower'; document.getElementById('vgalSearch').value=''; renderGalTiles(''); showGal(); }
  function openGalleryChangeAdd(piece,ai){ galTarget={piece:piece, addIndex:ai}; ensureGal(); document.getElementById('vgalTitle').textContent='Swap this flower'; document.getElementById('vgalSearch').value=''; renderGalTiles(''); showGal(); }
  function openGalleryAlc(){ galTarget={alacarte:true}; galFilter='all'; ensureGal(); document.getElementById('vgalTitle').textContent='Add an extra flower'; document.getElementById('vgalSearch').value=''; renderGalTiles(''); showGal(); }
  function openGalleryChangeAlc(i){ galTarget={alcIndex:i}; ensureGal(); document.getElementById('vgalTitle').textContent='Swap this flower'; document.getElementById('vgalSearch').value=''; renderGalTiles(''); showGal(); }
  function galCurrent(){ if(!galTarget) return null; if(galTarget.add) return null; if(galTarget.alacarte) return null; if(galTarget.alcIndex!=null){ return alacarte[galTarget.alcIndex]?alacarte[galTarget.alcIndex].name:null; } if(galTarget.addIndex!=null){ var arr=additions[galTarget.piece]||[]; return arr[galTarget.addIndex]?arr[galTarget.addIndex].name:null; } if(galTarget.piece) return slotFlower(byId[galTarget.piece], galTarget.idx); return palette[galTarget.role][galTarget.idx]; }
  function galSelect(name){ if(!galTarget) return;
    if(galTarget.alacarte){ alacarte.push({name:name, bunches:1}); closeGal(); renderResults(); saveState(); return; }
    if(galTarget.alcIndex!=null){ alacarte[galTarget.alcIndex].name=name; closeGal(); renderResults(); saveState(); return; }
    if(galTarget.add){ var pr=prod(name); var role=pr?pr.role:'focal'; var unit=(role==='greenery'||role==='filler')?'b':'s'; additions[galTarget.piece]=additions[galTarget.piece]||[]; additions[galTarget.piece].push({name:name, amt:unit==='b'?0.25:5, unit:unit}); closeGal(); renderResults(); saveState(); return; }
    if(galTarget.addIndex!=null){ var a=additions[galTarget.piece][galTarget.addIndex]; var pr2=prod(name); var role2=pr2?pr2.role:'focal'; a.name=name; a.unit=(role2==='greenery'||role2==='filler')?'b':'s'; closeGal(); renderResults(); saveState(); return; }
    if(galTarget.piece){ overrides[galTarget.piece]=overrides[galTarget.piece]||{}; overrides[galTarget.piece][galTarget.idx]=name; if(galTarget.piece==='greenery-rect' && galTarget.idx===0){ amounts['greenery-rect']=amounts['greenery-rect']||[0]; amounts['greenery-rect'][0]= /italian ruscus/i.test(name)?1:0.75; } closeGal(); renderResults(); saveState(); } else { palette[galTarget.role][galTarget.idx]=name; touched[galTarget.role+'|'+galTarget.idx]=true; closeGal(); renderPalette(); saveState(); } }
  function closeGal(){ var g=document.getElementById('bcfVgal'); if(g) g.classList.remove('on'); galTarget=null; }
  function galTile(o, label){
    var url=(window.BCF_PHOTOS||{})[o.name];
    var img=url?'<span class="vtile-img"><img src="'+url+'" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;display:block;" loading="lazy" /></span>':'<span class="vtile-img ph"></span>';
    var sel=(galCurrent()===o.name)?' on':'';
    return '<button type="button" class="vtile'+sel+'" data-name="'+o.name.replace(/"/g,'&quot;')+'">'+img+'<span class="vtile-name">'+label+'</span></button>';
  }
  function renderGalChips(){
    var wrap=document.getElementById('vgalChips'); if(!wrap) return;
    var isAdd = galTarget && (galTarget.add || galTarget.addIndex!=null || galTarget.alacarte || galTarget.alcIndex!=null);
    if(!isAdd){ wrap.style.display='none'; wrap.innerHTML=''; return; }
    wrap.style.display='flex';
    var ORDER=['greenery','focal','line','spray','detail','filler'];
    var SHORT={greenery:'Greenery',focal:'Focal',line:'Line',spray:'Spray',detail:'Detail',filler:'Filler'};
    var present={}; PRODUCTS.forEach(function(o){ present[o.role]=true; });
    var chips=['<button type="button" class="vchip'+(galFilter==='all'?' on':'')+'" data-filter="all">All</button>'];
    ORDER.forEach(function(r){ if(present[r]) chips.push('<button type="button" class="vchip'+(galFilter===r?' on':'')+'" data-filter="'+r+'">'+SHORT[r]+'</button>'); });
    wrap.innerHTML=chips.join('');
    wrap.querySelectorAll('[data-filter]').forEach(function(b){ b.addEventListener('click',function(){ galFilter=b.getAttribute('data-filter'); renderGalChips(); renderGalTiles(document.getElementById('vgalSearch').value); }); });
  }
  function renderGalTiles(q){
    renderGalTilesInner(q);
    var grid=document.getElementById('vgalGrid');
    var el=grid;
    while(el && el.id!=='bcfVgal'){ el.scrollTop=0; el=el.parentElement; }
    var modal=document.getElementById('bcfVgal'); if(modal) modal.scrollTop=0;
  }
  function renderGalTilesInner(q){
    if(!galTarget) return;
    var role=galTarget.role; q=(q||'').toLowerCase().trim();
    var grid=document.getElementById('vgalGrid');
    if(grid){ requestAnimationFrame(function(){ grid.scrollTop=0; }); }
    var groups={}, gorder=[];
    prodsByRole(role).forEach(function(o){ var t=splitName(o.name).type; if(!groups[t]){groups[t]=[];gorder.push(t);} groups[t].push(o); });
    function match(o){ return !q || o.name.toLowerCase().indexOf(q)>=0; }
    function attach(){ grid.querySelectorAll('.vtile').forEach(function(b){ b.addEventListener('click',function(){ galSelect(b.getAttribute('data-name')); }); }); }
    renderGalChips();
    if(galTarget.add || galTarget.addIndex!=null || galTarget.alacarte || galTarget.alcIndex!=null){
      var seen={}; var all=PRODUCTS.filter(function(o){ if(seen[o.name])return false; seen[o.name]=1; return match(o) && (galFilter==='all'||o.role===galFilter); });
      var ORDER=['greenery','focal','line','spray','detail','filler'];
      var byRole={}; all.forEach(function(o){ (byRole[o.role]=byRole[o.role]||[]).push(o); });
      var ghtml='';
      ORDER.forEach(function(r){ var list=(byRole[r]||[]).sort(function(a,b){ return a.name.localeCompare(b.name,undefined,{sensitivity:'base'}); }); if(!list.length) return; ghtml+='<div class="vgal-gh">'+ROLE_NAME[r]+'</div><div class="vgal-row">'+list.map(function(o){ var sp=splitName(o.name); return galTile(o, sp.color?sp.type+' \u00b7 '+sp.color:sp.type); }).join('')+'</div>'; });
      grid.innerHTML = ghtml || '<div class="vgal-empty">No matches</div>';
      attach(); return;
    }
    if(role==='greenery'){
      var glist=prodsByRole(role).filter(match).slice().sort(function(a,b){ return a.name.localeCompare(b.name, undefined, {sensitivity:'base'}); });
      grid.innerHTML = glist.length ? '<div class="vgal-row">'+glist.map(function(o){ var sp=splitName(o.name); return galTile(o, sp.color?sp.type+' \u00b7 '+sp.color:sp.type); }).join('')+'</div>' : '<div class="vgal-empty">No matches</div>';
      attach(); return;
    }
    var singles=[], multis=[];
    gorder.forEach(function(t){ (groups[t].length>1?multis:singles).push(t); });
    multis.sort(function(a,b){ return a.localeCompare(b); });
    singles.sort(function(a,b){ return a.localeCompare(b); });
    var html='';
    multis.forEach(function(t){
      var tiles=groups[t].filter(match);
      if(!tiles.length) return;
      html+='<div class="vgal-gh">'+t+'</div><div class="vgal-row">'+tiles.map(function(o){ return galTile(o, splitName(o.name).color||'Standard'); }).join('')+'</div>';
    });
    var singleTiles=[];
    singles.forEach(function(t){ groups[t].forEach(function(o){ if(match(o)) singleTiles.push(galTile(o, splitName(o.name).type)); }); });
    if(singleTiles.length) html+='<div class="vgal-gh">More options</div><div class="vgal-row">'+singleTiles.join('')+'</div>';
    grid.innerHTML=html||'<div class="vgal-empty">No matches</div>';
    attach();
  }

  /* ---------------- STEP 3: recipes ---------------- */
  function pieceFlowerForSlot(p, role, roleIndex){
    var arr=palette[role]||[];
    return arr[roleIndex] || arr[arr.length-1] || (prodsByRole(role)[0]||{}).name;
  }
  function ensureAmounts(){
    selectedPieces().forEach(function(p){
      if(!amounts[p.id]) amounts[p.id]=p.recipe.map(function(sl){ return sl[1]; });
      else p.recipe.forEach(function(sl,i){ if(amounts[p.id][i]==null) amounts[p.id][i]=sl[1]; else if(!p.greeneryOnly && amounts[p.id][i] < sl[1]) amounts[p.id][i]=sl[1]; });
      if(!removed[p.id]) removed[p.id]={};
    });
  }
  function slotFlower(p, slotIdx){
    if(overrides[p.id] && overrides[p.id][slotIdx]) return overrides[p.id][slotIdx];
    var role=p.recipe[slotIdx][0];
    var roleIdx=0;
    for(var i=0;i<slotIdx;i++){ if(p.recipe[i][0]===role) roleIdx++; }
    return pieceFlowerForSlot(p, role, roleIdx);
  }
  function thumbMini(name){ var url=(window.BCF_PHOTOS||{})[name]; var t=' title="'+String(name).replace(/"/g,'')+'"'; return url?'<span class="amini"'+t+'><img src="'+url+'" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;display:block;" loading="lazy" /></span>':'<span class="amini ph"'+t+'></span>'; }
  function renderResults(){
