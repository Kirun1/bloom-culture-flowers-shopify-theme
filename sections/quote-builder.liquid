  function setStep(n){
    step=n; maxReached=Math.max(maxReached,n); root.classList.remove('s2','s3');
    if(n===2) root.classList.add('s2');
    if(n===3) root.classList.add('s3');
    root.querySelectorAll('.stepdot').forEach(function(d){
      var s=+d.getAttribute('data-step');
      d.classList.toggle('on',s===n); d.classList.toggle('done',s<n);
    });
    document.getElementById('backBtn').style.display = 'inline-block';
    var next=document.getElementById('nextBtn');
    if(n===1){ next.textContent='Next: choose flowers \u2192'; updateBar(); }
    else if(n===2){ renderPalette(); next.textContent='Next: see recipes \u2192'; document.getElementById('barNum').innerHTML='<span class="z">Pick your flowers</span>'; document.getElementById('barLabel').textContent='Step 2 of 3'; updatePaletteBar(); }
    else if(n===3){ renderResults(); next.style.display='none'; }
    if(n<3) next.style.display='inline-block';
    try{ root.scrollIntoView({block:'start'}); }catch(e){}
    saveState();
  }
  function updateBar(){
    if(step!==1) return;
    var n=0; selectedPieces().forEach(function(p){ n+=p.qty; });
    var num=document.getElementById('barNum'), next=document.getElementById('nextBtn'), lbl=document.getElementById('barLabel');
    if(n===0){ num.innerHTML='<span class="z">Add items to begin</span>'; lbl.textContent='Your arrangements'; next.disabled=true; }
    else { num.textContent=n+(n===1?' arrangement':' arrangements'); lbl.textContent='Selected'; next.disabled=false; }
  }
  function restart(){
    CATS.forEach(function(c){ c.pieces.forEach(function(p){ p.qty=0; }); });
    palette={}; touched={}; amounts={}; removed={}; overrides={}; additions={}; alacarte=[]; openArrs={}; closedCats={}; leadEmail=null; leadName=null;
    try{ localStorage.removeItem(SKEY); }catch(e){}
    try{ sessionStorage.removeItem(SKEY); }catch(e){}
    renderSections(); setStep(1);
  }

  document.getElementById('nextBtn').addEventListener('click',function(){ if(this.disabled) return; setStep(Math.min(3,step+1)); });
  document.getElementById('backBtn').addEventListener('click',function(){ if(step>1){ setStep(Math.max(1,step-1)); } else { history.back(); } });
  root.querySelectorAll('.stepdot').forEach(function(d){ d.addEventListener('click',function(){
    var target=+d.getAttribute('data-step');
    var hasPieces=false; selectedPieces().forEach(function(p){ if(p.qty>0) hasPieces=true; });
    if(target>1 && !hasPieces) return; // can't advance past step 1 until something is picked
    if(target>maxReached) return; // can't skip ahead (must go through step 2 before step 3); back is always allowed
    setStep(target);
  }); });

  var _saved=loadState();
  renderSections();

  var PRESETS = {
    small:  { 'bridal-bouquet':1, 'bridesmaid-bouquet':2, 'boutonniere':2, 'cp-small':4 },
    medium: { 'bridal-bouquet':1, 'bridesmaid-bouquet':3, 'boutonniere':4, 'corsage':2, 'cp-medium':8 },
    large:  { 'bridal-bouquet':1, 'bridesmaid-bouquet':5, 'boutonniere':5, 'corsage':2, 'cp-large':12, 'aisle-statement':2 }
  };
  function applyPreset(name){
    var pre=PRESETS[name]; if(!pre) return;
    CATS.forEach(function(c){ c.pieces.forEach(function(x){ x.qty = pre[x.id]||0; }); });
    renderSections(); updateBar(); saveState();
    root.querySelectorAll('.qscard').forEach(function(b){ b.classList.toggle('on', b.getAttribute('data-preset')===name); });
    var first=document.getElementById('sections'); if(first){ window.scrollTo({ top:first.getBoundingClientRect().top+window.scrollY-90, behavior:'smooth' }); }
  }
  root.querySelectorAll('.qscard').forEach(function(b){ b.addEventListener('click',function(e){ e.stopPropagation(); applyPreset(b.getAttribute('data-preset')); var t=root.querySelector('.qstrig'); if(t){ t.classList.remove('on'); t.blur(); } }); });
  var _qtrig=root.querySelector('.qstrig');
  if(_qtrig){ _qtrig.addEventListener('click',function(e){ e.stopPropagation(); _qtrig.classList.toggle('on'); }); }

  root.addEventListener('click',function(e){ if(!e.target.closest('.help')) root.querySelectorAll('.help.on').forEach(function(x){ x.classList.remove('on'); }); if(!e.target.closest('.qstrig')){ var t=root.querySelector('.qstrig'); if(t) t.classList.remove('on'); } });
  setStep(_saved && _saved.qty && Object.keys(_saved.qty).length ? (_saved.step||1) : 1);
})();
</script>

