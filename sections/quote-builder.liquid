<script>
(function(){
  var root = document.getElementById('bcf-quote');
  var PRODUCTS = window.BCF_PRODUCTS, CATS = window.BCF_CATEGORIES;

  /* Auto-detect sticky header height so gallery popup clears the nav */
  (function detectHeader(){
    var hdr = document.querySelector('.header-sections, .site-header, header, [data-site-header]');
    if (hdr) {
      var h = hdr.getBoundingClientRect().height;
      if (h > 20 && h < 200) root.style.setProperty('--bcf-header-h', h + 'px');
    }
  })();

  var CUSTOM_URL = 'https://bloomcultureflowers.com/pages/custom-floral-design';

  var ROLE_NAME = { greenery:'Greenery', line:'Line flower', focal:'Focal flower', large:'Statement flower', spray:'Spray flower', detail:'Detail flower', filler:'Filler flower' };
  var ROLE_DESC = {
    greenery:'The foliage is the base of the arrangements.',
    line:'Long stems with blooms along the stem, add height or length, and create movement.',
    focal:'Your star blooms, the eye lands here.',
    large:'Big statement blooms like hydrangea, used in the larger arrangements you selected.',
    spray:'Multi-bloom stems that fill and soften.',
    detail:'Special accent blooms for texture.',
    filler:'Airy little blooms that tie it together and fill in space. '
  };
  var ROLE_ORDER = ['greenery','focal','spray','line','detail','filler','large'];

  /* state */
  var step = 1;
  var maxReached = 1;
  var byId = {};
  CATS.forEach(function(c){ c.pieces.forEach(function(p){ p.qty=0; byId[p.id]=p; }); });
  var palette = {};   // role -> [flowerName per slot index]
  var touched = {};   // role|idx -> true once the couple actively picks (clears the EX state)
  var amounts = {};   // pieceId -> [amount per slot]
  var removed = {};   // pieceId -> { slotIndex:true }
  var overrides = {}; // pieceId -> { slotIndex:flowerName }  (per-piece flower swap)
  var openArrs = {};  // pieceId -> true when its recipe card is expanded on step 3
  var closedCats = {}; // categoryId -> true when its section is collapsed on step 3 (open by default)
  var additions = {}; // pieceId -> [{name, amt, unit}]  (extra flowers the couple adds to a recipe)
  var alacarte = []; // [{name, bunches}]  (whole wholesale bunches added to the order, not tied to a recipe)
  var leadEmail = null; // soft lead-capture email (optional "email me my plan")
  var leadName = null;  // soft lead-capture full name (paired with leadEmail)

  function prodsByRole(role){ return PRODUCTS.filter(function(p){ return p.role===role; }); }
  function isOpt(sl){ return !!sl[3] || sl[0]==='filler'; } // filler is always optional/removable
  var TYPE_FIX={'Carnations':'Carnation','Mini Carnations':'Mini Carnation','Peonies':'Peony','Snapdragons':'Snapdragon','Football Mums':'Football Mum','Vintage Carnations':'Carnation','Sunflowers':'Sunflower','Waxflower':'Wax Flower'};
  function splitName(name){
    var type, color, m=name.match(/^(.*?)\s*-\s*(.*)$/);
    if(m){ type=m[1].trim(); color=m[2].trim(); }
    else { var pm=name.match(/^(.*?)\s*\(([^)]+)\)\s*$/); if(pm){ type=pm[1].trim(); color=pm[2].trim(); } else { type=name.trim(); color=''; } }
    if(TYPE_FIX[type]) type=TYPE_FIX[type];
    return {type:type, color:color};
  }
  function typesInRole(role){ var seen=[],map={}; prodsByRole(role).forEach(function(p){ var t=splitName(p.name).type; if(!map[t]){ map[t]=1; seen.push(t); } }); return seen; }
  function colorsForType(role,type){ return prodsByRole(role).filter(function(p){ return splitName(p.name).type===type; }); }
  function colorNeutral(role,type){ var list=colorsForType(role,type); if(!list.length) return ''; for(var i=0;i<list.length;i++){ if(/\bwhite\b/i.test(list[i].name)) return list[i].name; } for(var j=0;j<list.length;j++){ if(/cream|ivory/i.test(list[j].name)) return list[j].name; } return list[0].name; }
  function pieceImg(id){ return (window.BCF_PIECE_PHOTOS||{})[id]; }
  function helpBtn(id){
    var url=pieceImg(id);
    if(!url) return '';
    return '<button class="help" data-help="'+id+'" aria-label="See an example">?<span class="pop"><img src="'+url+'" alt="" /></span></button>';
  }
  function prod(name){ return PRODUCTS.find(function(p){ return p.name===name; }); }
  function money(n){ return '$'+Math.round(n).toLocaleString('en-US'); }
  function roleOf(name){ var pr=prod(name); return pr?pr.role:''; }
  function thumb(name){
    var url=(window.BCF_PHOTOS||{})[name];
    if(url) return '<span class="thmb"><img src="'+url+'" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;display:block;" loading="lazy" /></span>';
    return '<span class="thmb ph"></span>';
  }
  function vthumb(name){
    var url=(window.BCF_PHOTOS||{})[name];
    if(url) return '<span class="vthumb"><img src="'+url+'" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;display:block;" loading="lazy" /></span>';
    return '<span class="vthumb ph"></span>';
  }
  function frac(v){
    var opts=[[1,'1'],[0.75,'3/4'],[2/3,'2/3'],[0.5,'1/2'],[1/3,'1/3'],[0.25,'1/4'],[1/5,'1/5'],[1/6,'1/6'],[1/7,'1/7']];
    for(var i=0;i<opts.length;i++){ if(Math.abs(opts[i][0]-v)<0.02) return opts[i][1]; }
    return (Math.round(v*100)/100)+'';
  }

  /* ---------------- progress persistence (so a reload keeps your place) ---------------- */
  var SKEY='bcf_quote_state_v1';
  function saveState(){
    try{
      var qty={}; CATS.forEach(function(c){ c.pieces.forEach(function(p){ if(p.qty>0) qty[p.id]=p.qty; }); });
      var data = JSON.stringify({ step:step, qty:qty, palette:palette, touched:touched, amounts:amounts, removed:removed, overrides:overrides, additions:additions, alacarte:alacarte, leadEmail:leadEmail, leadName:leadName });
      try { localStorage.setItem(SKEY, data); } catch(e) { sessionStorage.setItem(SKEY, data); }
    }catch(e){}
  }
  function loadState(){
    try{
      var raw;
      try { raw = localStorage.getItem(SKEY); } catch(e){}
      if(!raw) { try { raw = sessionStorage.getItem(SKEY); } catch(e){} }
      if(!raw) return null;
      var s=JSON.parse(raw); if(!s||!s.qty) return null;
      CATS.forEach(function(c){ c.pieces.forEach(function(p){ p.qty=s.qty[p.id]||0; }); });
      palette=s.palette||{}; touched=s.touched||{}; amounts=s.amounts||{}; removed=s.removed||{}; overrides=s.overrides||{}; additions=s.additions||{}; alacarte=s.alacarte||[]; leadEmail=s.leadEmail||null; leadName=s.leadName||null;
      return s;
    }catch(e){ return null; }
  }
  document.addEventListener('visibilitychange', function(){
    if (document.visibilityState === 'hidden') saveState();
  });
  function refreshCounts(){
    CATS.forEach(function(c){ var n=0; c.pieces.forEach(function(x){ n+=x.qty; }); var el=root.querySelector('[data-seccount="'+c.id+'"]'); if(el){ el.textContent=n?n+' selected':''; el.classList.toggle('on',n>0); } });
  }

  /* ---------------- STEP 1 ---------------- */
  function renderSections(){
    var host=document.getElementById('sections');
    host.innerHTML = CATS.map(function(cat,ci){
      if(!cat.pieces.length) return '';
      var rows = cat.pieces.map(function(p){
        var note = p.note ? '<div class="inote">'+p.note+'</div>' : (p.greeneryOnly?'<div class="inote">Greenery only</div>':'');
        return '<div class="item'+(p.qty>0?' on':'')+'" data-id="'+p.id+'">'+
          '<div class="info"><div class="iname">'+p.name+helpBtn(p.id)+'</div>'+note+'</div>'+
          '<div class="step">'+
            '<button data-dec="'+p.id+'" aria-label="Remove one"'+(p.qty>0?'':' disabled')+'>&#8722;</button>'+
            '<span class="qty" data-qty="'+p.id+'">'+p.qty+'</span>'+
            '<button data-inc="'+p.id+'" aria-label="Add one">+</button>'+
          '</div></div>';
      }).join('');
      return '<div class="sec'+(ci===0?' open':'')+'">'+
        '<button class="sechead" data-toggle="'+cat.id+'"><span class="st">'+cat.name+'</span>'+
        '<span class="smeta"><span class="scount" data-seccount="'+cat.id+'"></span>'+
        '<span class="chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></span></span></button>'+
        '<div class="secbody">'+rows+'</div></div>';
    }).join('');

    host.querySelectorAll('[data-toggle]').forEach(function(b){ b.addEventListener('click',function(){ b.closest('.sec').classList.toggle('open'); }); });
    host.querySelectorAll('[data-inc]').forEach(function(b){ b.addEventListener('click',function(){ chQty(b.getAttribute('data-inc'),1); }); });
    host.querySelectorAll('[data-dec]').forEach(function(b){ b.addEventListener('click',function(){ chQty(b.getAttribute('data-dec'),-1); }); });
    host.querySelectorAll('[data-help]').forEach(function(b){ b.addEventListener('click',function(e){ e.preventDefault(); e.stopPropagation(); var open=b.classList.contains('on'); host.querySelectorAll('.help.on').forEach(function(x){ x.classList.remove('on'); }); if(!open) b.classList.add('on'); }); });
    refreshCounts();
  }
  function chQty(id,delta){
    var p=byId[id]; p.qty=Math.max(0,p.qty+delta);
    var row=root.querySelector('.item[data-id="'+id+'"]');
    row.classList.toggle('on',p.qty>0);
    row.querySelector('[data-qty="'+id+'"]').textContent=p.qty;
    row.querySelector('[data-dec="'+id+'"]').disabled=p.qty===0;
    root.querySelectorAll('.qscard.on').forEach(function(b){ b.classList.remove('on'); });
    refreshCounts();
    updateBar();
    saveState();
  }
  function selectedPieces(){ var a=[]; CATS.forEach(function(c){ c.pieces.forEach(function(p){ if(p.qty>0) a.push(p); }); }); return a; }

  /* ---------------- STEP 2: palette ---------------- */
  function rolesNeeded(){
    // role -> max slot count across selected pieces (ignoring removed not yet known)
    var max={};
    selectedPieces().forEach(function(p){
      var per={};
      p.recipe.forEach(function(sl){ per[sl[0]]=(per[sl[0]]||0)+1; });
      for(var r in per){ max[r]=Math.max(max[r]||0, per[r]); }
    });
    return max;
  }
  function buildDefaults(){
    var max=rolesNeeded();
    var EX_DEFAULTS={ greenery:['Eucalyptus','Salal / Lemon Leaf','Leather Leaf'], line:['Stock','Delphinium'], large:['Hydrangea'], focal:['Rose','Carnation'], spray:['Spray Rose','Mini Carnation'], detail:['Ranunculus'], filler:["Baby's Breath"] };
    ROLE_ORDER.forEach(function(role){
      if(!max[role]) return;
      palette[role]=palette[role]||[];
      // seed defaults from recipes: collect default flowers seen per index
      var seen=[];
      selectedPieces().forEach(function(p){
        var idx=0;
        p.recipe.forEach(function(sl){
          if(sl[0]!==role) return;
          if(sl[4] && !seen[idx]) seen[idx]=sl[4];
          idx++;
        });
      });
      for(var i=0;i<max[role];i++){
        var ekey=role+'|'+i;
        if(touched[ekey]){ if(!palette[role][i]) palette[role][i]=neutralFor(role); continue; }
        var bare=(EX_DEFAULTS[role] && EX_DEFAULTS[role][i]) || seen[i];
        palette[role][i] = resolveDefault(role, bare) || resolveDefault(role, seen[i]) || neutralFor(role);
      }
      palette[role].length=max[role];
    });
  }
  function neutralFor(role){
    var list=prodsByRole(role); if(!list.length) return '';
    function find(re){ for(var i=0;i<list.length;i++){ if(re.test(list[i].name)) return list[i].name; } return null; }
    if(role==='greenery') return find(/salal\/lemon|silver dollar/i) || find(/eucalyptus/i) || list[0].name;
    if(role==='filler') return find(/wax flower .*white|baby's breath/i) || find(/white|cream|ivory/i) || list[0].name;
    if(role==='focal') return find(/^rose - white/i) || find(/rose - cream|rose - vendela/i) || find(/\bwhite\b/i) || list[0].name;
    if(role==='line') return find(/stock - white|snapdragon.*white/i) || find(/\bwhite\b/i) || list[0].name;
    return find(/\bwhite\b/i) || find(/cream|ivory/i) || list[0].name;
  }
  function norm(s){ return (s||'').toLowerCase().replace(/\s*\/\s*/g,'/').replace(/\s+/g,' ').trim(); }
  function resolveDefault(role, bare){
    if(!bare) return null;
    if(prod(bare)) return bare;
    var list=prodsByRole(role); var nb=norm(bare);
    var matches=list.filter(function(o){ return norm(splitName(o.name).type)===nb; });
    if(!matches.length) matches=list.filter(function(o){ return norm(o.name).indexOf(nb)>=0; });
    if(!matches.length) return null;
    for(var i=0;i<matches.length;i++){ if(/\bwhite\b/i.test(matches[i].name)) return matches[i].name; }
    for(var j=0;j<matches.length;j++){ if(/cream|ivory/i.test(matches[j].name)) return matches[j].name; }
    return matches[0].name;
  }
  function renderPalette(){
    buildDefaults();
    var max=rolesNeeded();
    var mount=document.getElementById('paletteMount');
    mount.innerHTML = ROLE_ORDER.filter(function(r){ return max[r]; }).map(function(role){
      var opts=prodsByRole(role);
      var slots='';
      for(var i=0;i<max[role];i++){
        var cur=palette[role][i]; var ct=splitName(cur);
        var key=role+'|'+i;
        var isEx = !touched[key];
        var dispName = isEx ? ('ex. '+ct.type) : (ct.type + (ct.color?' \u00b7 '+ct.color : ''));
        slots+='<div class="pslot'+(isEx?' ex':'')+'"><span class="plabel">'+ROLE_NAME[role]+' '+(i+1)+'</span>'+
          '<button type="button" class="vpick'+(isEx?' ex':'')+'" data-role="'+role+'" data-idx="'+i+'">'+
            vthumb(cur)+'<span class="vname">'+dispName+'</span>'+
            '<span class="vchev"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></span></button></div>';
      }
      var dupNames={}, hasDup=false;
      for(var di=0; di<max[role]; di++){ var dn=norm(palette[role][di]); if(!dn) continue; if(dupNames[dn]) hasDup=true; dupNames[dn]=1; }
      var dupNote = hasDup ? '<div class="dupnote"><span class="floret">&#10047;</span> Picked the same '+ROLE_NAME[role].toLowerCase()+' twice? Lovely \u2014 we\u2019ll simply combine it into one accurate amount.</div>' : '';
      return '<div class="roleblock"><h3><span class="floret">&#10047;</span> '+ROLE_NAME[role]+(max[role]>1 && role!=='greenery' ?'s':'')+(role==='filler'?'<span class="roleopt">optional</span>':'')+'</h3>'+
        '<div class="rdesc">'+ROLE_DESC[role]+'</div><div class="roleslots">'+slots+'</div>'+dupNote+'</div>';
    }).join('');
    mount.querySelectorAll('.vpick').forEach(function(b){
      b.addEventListener('click',function(){ openGallery(b.getAttribute('data-role'), +b.getAttribute('data-idx')); });
    });
    updatePaletteBar();
  }
  function paletteRemaining(){
    var max=rolesNeeded(), rem=0;
    ROLE_ORDER.forEach(function(role){ if(!max[role]||role==='filler') return; for(var i=0;i<max[role];i++){ if(!touched[role+'|'+i]) rem++; } });
    return rem;
  }
  function updatePaletteBar(){
    if(step!==2) return;
    var rem=paletteRemaining();
    var next=document.getElementById('nextBtn'), lbl=document.getElementById('barLabel'), num=document.getElementById('barNum');
    if(rem>0){ num.innerHTML='<span class="z">Pick your flowers</span>'; lbl.textContent=rem+(rem===1?' flower left to choose':' flowers left to choose'); next.disabled=true; }
    else { num.innerHTML='<span class="z">Flowers picked</span>'; lbl.textContent='Step 2 of 3'; next.disabled=false; }
  }
  var galTarget=null;
  var galFilter='all'; // type filter for the add / à la carte gallery
  function ensureGal(){
    var g=document.getElementById('bcfVgal');
    if(g) return g;
