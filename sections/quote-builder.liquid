      var qtyCtl=' <span class="atqty"><span class="aqlabel">Qty</span><span class="aqv">'+p.qty+'</span><span class="aqspin"><button type="button" data-aqinc="'+p.id+'" aria-label="More"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 15 6-6 6 6"/></svg></button><button type="button" data-aqdec="'+p.id+'" aria-label="Fewer"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button></span></span>';
      var vis=p.recipe.map(function(sl,i){return i;}).filter(function(i){ return !(isOpt(p.recipe[i]) && removed[p.id]&&removed[p.id][i]); });
      var strip=vis.map(function(i){ return thumbMini(slotFlower(p,i)); }).join('');
      var addSlots=(additions[p.id]||[]).map(function(a,ai){
        var pr=prod(a.name)||{}; var role=pr.role||'focal';
        var sp=splitName(a.name); var dn=sp.color?sp.type+' \u00b7 '+sp.color:sp.type;
        var amtCtl=a.unit==='b'
          ? '<div class="amt"><button data-addec="'+p.id+'|'+ai+'">&#8722;</button><span class="av" data-adav="'+p.id+'|'+ai+'">'+frac(a.amt)+' bu</span><button data-adinc="'+p.id+'|'+ai+'">+</button></div>'
          : '<div class="amt"><button data-addec="'+p.id+'|'+ai+'">&#8722;</button><span class="av" data-adav="'+p.id+'|'+ai+'">'+a.amt+' st</span><button data-adinc="'+p.id+'|'+ai+'">+</button></div>';
        return '<div class="slot added"><button type="button" class="rpick" data-arp="'+p.id+'|'+ai+'">'+thumb(a.name)+'<span class="rinfo"><span class="rrole">'+ROLE_NAME[role]+' \u00b7 added</span><span class="rname">'+dn+'</span></span><span class="rchev"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></span></button>'+amtCtl+'<button class="rm" data-adrm="'+p.id+'|'+ai+'" title="Remove">&times;</button></div>';
