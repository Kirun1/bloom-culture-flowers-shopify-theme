  function chAmt(key,delta){
    var k=key.split('|'), id=k[0], i=+k[1];
    var p=byId[id], unit=p.recipe[i][2], floor=p.recipe[i][1];
    if(unit==='b'){
      var steps=[1/7,1/6,1/5,1/4,1/3,1/2,2/3,3/4,1,1.25,1.5,2,3,4];
      var cur=amounts[id][i], idx=0, best=1e9;
      steps.forEach(function(v,j){ if(Math.abs(v-cur)<best){ best=Math.abs(v-cur); idx=j; } });
      idx=Math.max(0,Math.min(steps.length-1,idx+delta));
      var nv=steps[idx]; if(nv<floor-1e-9) nv=floor;
      amounts[id][i]=nv;
    } else {
      amounts[id][i]=Math.max(floor, amounts[id][i]+delta);
    }
    recompute();
  }
  function chAdd(pid,ai,delta){ var a=additions[pid][ai]; if(!a) return; if(a.unit==='b'){ var steps=[1/4,1/3,1/2,2/3,3/4,1,1.25,1.5,2,3,4]; var cur=a.amt,idx=0,best=1e9; steps.forEach(function(v,j){ if(Math.abs(v-cur)<best){best=Math.abs(v-cur);idx=j;} }); idx=Math.max(0,Math.min(steps.length-1,idx+delta)); a.amt=steps[idx]; } else { a.amt=Math.max(1,a.amt+delta); } recompute(); saveState(); }
  function recompute(){
    // per-slot amount labels + per-arrangement cost + master demand
    var demand={}; var order=[];
    selectedPieces().forEach(function(p){
      var mult=(p.mult||1)*p.qty;
      p.recipe.forEach(function(sl,i){
        var role=sl[0], unit=sl[2];
        var av=root.querySelector('[data-av="'+p.id+'|'+i+'"]');
        if(av) av.textContent = unit==='b' ? frac(amounts[p.id][i])+' bu' : amounts[p.id][i]+' st';
        if(isOpt(sl) && removed[p.id] && removed[p.id][i]) return;
        var fl=slotFlower(p,i); var pr=prod(fl); if(!pr) return;
        var units = amounts[p.id][i]; // stems or bunch-fraction
        var bunchUnits = unit==='b' ? units : units/pr.stems;
        var key=role+'|'+fl;
        if(!demand[key]){ demand[key]={name:fl, bunchUnits:0}; order.push(key); }
        demand[key].bunchUnits += bunchUnits * mult;
      });
      (additions[p.id]||[]).forEach(function(a,ai){
        var adav=root.querySelector('[data-adav="'+p.id+'|'+ai+'"]'); if(adav) adav.textContent = a.unit==='b'?frac(a.amt)+' bu':a.amt+' st';
        var pr=prod(a.name); if(!pr) return; var bu=a.unit==='b'?a.amt:a.amt/pr.stems;
        var akey=pr.role+'|'+a.name;
        if(!demand[akey]){ demand[akey]={name:a.name, bunchUnits:0}; order.push(akey); }
        demand[akey].bunchUnits += bu * mult;
      });
    });
    alacarte.forEach(function(a){ var pr=prod(a.name); if(!pr) return; var key='alc|'+a.name; if(!demand[key]){ demand[key]={name:a.name, label:a.name+' \u00b7 extra', bunchUnits:0}; order.push(key); } demand[key].bunchUnits += a.bunches; });
    var total=0, rows='';
    order.forEach(function(key){
      var d=demand[key]; var pr=prod(d.name);
      var bunches=Math.max(d.bunchUnits>0?1:0, Math.ceil(d.bunchUnits-1e-9));
      var cost=bunches*pr.bunch; total+=cost;
      rows+='<div class="bline"><span class="bn"><b>'+bunches+'</b>'+(d.label||d.name)+'</span><span class="bc">'+money(cost)+'</span></div>';
    });
    var ml=document.getElementById('masterList'); if(ml) ml.innerHTML=rows;
    var pieceCount=0; selectedPieces().forEach(function(p){ pieceCount += p.qty*(p.mult||1); });
    var tn=document.getElementById('totalNum'); if(tn) tn.textContent=money(total);
    var tm=document.getElementById('totalMeta'); if(tm) tm.innerHTML='Everything you need for your wedding flower package.<span class="tcship"><span class="floret">&#10047;</span> Your order qualifies for free shipping.</span>';
    document.getElementById('barNum').textContent=money(total);
    document.getElementById('barLabel').textContent='Your running total';
    saveState();
  }

