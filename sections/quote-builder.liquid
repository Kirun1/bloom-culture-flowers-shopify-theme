    }
    CATS.forEach(function(cat){ var cp=cat.pieces.filter(function(x){return x.qty>0;}); if(!cp.length) return; html+='<div class="rescat'+(closedCats[cat.id]?'':' open')+'"><button type="button" class="rescathead" data-cattoggle="'+cat.id+'"><span class="catname">'+cat.name+'</span><span class="catchev"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></span></button><div class="rescatbody">'+cp.map(renderPiece).join('')+'</div></div>'; });

    var alcRows = alacarte.length
      ? alacarte.map(function(a,ai){ var sp=splitName(a.name); var dn=sp.color?sp.type+' \u00b7 '+sp.color:sp.type; return '<div class="slot"><button type="button" class="rpick" data-alcp="'+ai+'">'+thumb(a.name)+'<span class="rinfo"><span class="rrole">Extra</span><span class="rname">'+dn+'</span></span><span class="rchev"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></span></button><div class="amt"><button data-aldec="'+ai+'">&#8722;</button><span class="av">'+a.bunches+' bu</span><button data-alinc="'+ai+'">+</button></div><button class="rm" data-alrm="'+ai+'" title="Remove">&times;</button></div>'; }).join('')
      : '<div class="slot"><button type="button" class="rpick alc-ph-row" data-alcadd="1"><span class="thmb ph"></span><span class="rinfo"><span class="rrole">Extra</span><span class="rname alc-ph">Choose a flower</span></span><span class="rchev"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></span></button></div>';
