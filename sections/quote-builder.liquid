    g.innerHTML='<div class="vgal-card">'+
      '<div class="vgal-top"><span class="vgal-title" id="vgalTitle"></span><button type="button" class="vgal-x" id="vgalX" aria-label="Close">&times;</button></div>'+
      '<input type="text" class="vgal-search" id="vgalSearch" placeholder="Search by name\u2026" />'+
      '<div class="vgal-chips" id="vgalChips"></div>'+
      '<div class="vgal-grid" id="vgalGrid"></div>'+
      '<div class="vgal-foot">Don’t see the bloom you were looking for? Some specialty flowers are seasonal or available only through a <a href="'+CUSTOM_URL+'" target="_blank" rel="noopener">custom design</a>.</div></div>';
    root.appendChild(g);
    g.addEventListener('click',function(e){ if(e.target===g) closeGal(); });
    document.getElementById('vgalX').addEventListener('click',closeGal);
    document.getElementById('vgalSearch').addEventListener('input',function(){ renderGalTiles(this.value); });
    return g;
