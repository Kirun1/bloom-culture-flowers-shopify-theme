<style>
  #bcf-quote{
    --cream:#f7f6f0; --cream-deep:#eeece1; --paper:#fff;
    --ink:#2c352a; --ink-soft:#5d685a; --ink-faint:#98a18f;
    --line:#e6e3d6; --line-strong:#d6d2c3;
    --sage:#384d39; --sage-deep:#2b3c2c; --sage-tint:#e7ece3;
    --rose:#aa2138; --rose-deep:#8c1a2e; --rose-tint:#f5e2e4;
    --serif:'Cabin',Georgia,serif; --sans:'Montserrat',system-ui,sans-serif; --mono:'Archivo',sans-serif;
    --shadow-sm:0 1px 2px rgba(44,53,42,.05),0 2px 8px rgba(44,53,42,.04);
    --shadow-md:0 12px 30px rgba(44,53,42,.12);
  }
  #bcf-quote *{ box-sizing:border-box; margin:0; padding:0; }
  #bcf-quote{ font-family:var(--sans); color:var(--ink); background:var(--cream-deep); -webkit-font-smoothing:antialiased;
    width:100vw; margin-left:calc(50% - 50vw); padding-bottom:0; scroll-margin-top:120px; }
  #bcf-quote .wrap{ max-width:760px; margin:0 auto; padding:0 22px; }
  #bcf-quote button{ font-family:inherit; cursor:pointer; }
  #bcf-quote .floret{ color:var(--rose); }

  /* header photo */
  #bcf-quote .qphoto{ width:100vw; margin-left:calc(50% - 50vw); height:clamp(140px,18vw,220px); overflow:hidden; }
  #bcf-quote .qphoto img{ width:100%; height:100%; object-fit:cover; object-position:50% 58%; display:block; }

  /* step indicator */
  #bcf-quote .steps{ display:flex; align-items:center; justify-content:center; gap:10px; padding:26px 22px 4px; flex-wrap:wrap; }
  #bcf-quote .stepdot{ display:flex; align-items:center; gap:9px; font-family:var(--mono); font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-faint); cursor:pointer; }
  #bcf-quote .stepdot:hover .n{ border-color:var(--rose); }
  #bcf-quote .stepdot .n{ width:24px; height:24px; border-radius:50%; border:1.5px solid var(--line-strong); display:grid; place-items:center; font-size:11px; color:var(--ink-faint); }
  #bcf-quote .stepdot.on{ color:var(--rose); }
  #bcf-quote .stepdot.on .n{ border-color:var(--rose); background:var(--rose); color:#fff; }
  #bcf-quote .stepdot.done .n{ border-color:var(--sage); background:var(--sage); color:#fff; }
  #bcf-quote .stepsep{ width:22px; height:1px; background:var(--line-strong); }

  /* intro */
  #bcf-quote .intro{ text-align:center; max-width:720px; margin:0 auto; padding:14px 22px 6px; }
  #bcf-quote .kick{ font-family:var(--mono); font-size:11.5px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:var(--rose); margin-bottom:12px; }
  #bcf-quote .intro h1{ font-family:var(--serif); font-weight:500; font-size:clamp(16px,4.4vw,34px); line-height:1.1; letter-spacing:-.01em; color:var(--ink); white-space:nowrap; }
  #bcf-quote .intro h1 em{ font-style:italic; color:var(--sage); }
  #bcf-quote .intro p{ font-size:15.5px; line-height:1.55; color:#1b1b1b; margin:12px auto 0; max-width:480px; }
  #bcf-quote .savenote{ font-family:var(--mono); font-size:11px; font-weight:600; letter-spacing:.02em; color:var(--ink-soft); margin:16px auto 4px; text-align:center; }
  #bcf-quote .qstart{ text-align:center; margin:8px auto 2px; }
  #bcf-quote .qshint{ font-size:12.5px; color:var(--ink-soft); position:relative; }
  #bcf-quote .qstrig{ position:relative; color:var(--sage-deep); border-bottom:1px dashed var(--sage); cursor:pointer; font-weight:600; outline:none; }
  #bcf-quote .qspop{ display:none; position:absolute; bottom:calc(100% + 9px); left:50%; transform:translateX(-50%); width:262px; padding:7px; background:var(--paper); border:1px solid var(--line); border-radius:12px; box-shadow:0 14px 34px rgba(0,0,0,.14); z-index:120; }
  #bcf-quote .qstrig:hover .qspop, #bcf-quote .qstrig:focus .qspop, #bcf-quote .qstrig.on .qspop{ display:block; }
  #bcf-quote .qspop::after{ content:''; position:absolute; top:100%; left:50%; transform:translateX(-50%); border:7px solid transparent; border-top-color:var(--paper); }
  #bcf-quote .qspop::before{ content:''; position:absolute; top:100%; left:0; right:0; height:14px; }
  #bcf-quote .qscards{ display:flex; flex-direction:column; gap:6px; }
  #bcf-quote .qscard{ text-align:left; border:1px solid var(--line); background:transparent; border-radius:10px; padding:9px 11px; cursor:pointer; display:flex; flex-direction:column; gap:3px; transition:border-color .15s, background .15s; }
  #bcf-quote .qscard:hover{ border-color:var(--sage); background:rgba(56,77,57,.04); }
  #bcf-quote .qscard.on{ border-color:var(--rose); background:var(--rose-tint); }
  #bcf-quote .qsname{ font-family:var(--mono); font-size:10.5px; font-weight:700; letter-spacing:.05em; text-transform:uppercase; color:var(--ink-soft); }
  #bcf-quote .qscard:hover .qsname{ color:var(--sage-deep); }
  #bcf-quote .qscard.on .qsname{ color:var(--rose-deep); }
  #bcf-quote .qsdesc{ font-size:11.5px; line-height:1.4; color:var(--ink-soft); }

  #bcf-quote .intro .baseNote{ max-width:660px; margin:16px auto 0; background:var(--cream-deep); border:1px solid var(--line-strong); border-radius:12px; padding:12px 16px; font-size:13px; line-height:1.55; color:var(--ink); text-align:left; }
  #bcf-quote .intro .baseNote .bnIcon{ color:var(--rose); font-weight:700; margin-right:4px; }
  #bcf-quote .intro .baseNote b{ color:var(--rose); }
  #bcf-quote .howrow{ display:grid; grid-template-columns:repeat(3,1fr); gap:10px; max-width:720px; margin:18px auto 0; text-align:left; }
  #bcf-quote .howpt{ display:flex; gap:9px; align-items:flex-start; background:var(--paper); border:1px solid var(--line); border-radius:12px; padding:13px 14px; box-shadow:var(--shadow-sm); }
  #bcf-quote .howpt .hi{ flex-shrink:0; width:26px; height:26px; border-radius:50%; display:grid; place-items:center; color:#fff; font-size:12px; font-weight:700; }
  #bcf-quote .howpt:nth-child(1) .hi{ background:var(--rose); }
  #bcf-quote .howpt:nth-child(2) .hi{ background:var(--rose); }
  #bcf-quote .howpt:nth-child(3) .hi{ background:var(--rose); }
  #bcf-quote .howpt .ht{ font-size:12.5px; line-height:1.45; color:var(--ink-soft); }
  #bcf-quote .howpt .ht b{ color:var(--ink); font-weight:600; }
  @media (max-width:620px){ #bcf-quote .howrow{ grid-template-columns:1fr; gap:8px; } #bcf-quote .howpt{ padding:11px 13px; } }

  /* sections / accordion */
  #bcf-quote .sections{ margin-top:24px; }
  #bcf-quote .sec{ background:var(--paper); border:1px solid var(--line); border-radius:18px; margin-bottom:14px; overflow:visible; box-shadow:var(--shadow-sm); }
  #bcf-quote .sechead{ width:100%; display:flex; align-items:center; justify-content:space-between; gap:14px; padding:18px 22px; background:var(--sage-deep); border:0; text-align:left; }
  #bcf-quote .sechead .st{ font-family:var(--serif); font-weight:600; font-size:21px; color:var(--cream); display:flex; align-items:center; gap:10px; }
  #bcf-quote .sechead .st::before{ content:''; width:22px; height:22px; flex-shrink:0; background-image:url('https://cdn.shopify.com/s/files/1/0750/7984/4147/files/bcf_favicon.png?v=1765476178'); background-size:contain; background-repeat:no-repeat; background-position:center; }
  #bcf-quote .sechead .smeta{ display:flex; align-items:center; gap:12px; }
  #bcf-quote .sechead .scount{ font-family:var(--mono); font-size:11px; font-weight:700; color:var(--sage-deep); background:var(--cream); padding:5px 10px; border-radius:999px; opacity:0; transition:opacity .15s; }
  #bcf-quote .sechead .scount.on{ opacity:1; }
  #bcf-quote .sechead .chev{ color:var(--cream); opacity:.75; transition:transform .2s; }
  #bcf-quote .sec.open .sechead .chev{ transform:rotate(180deg); }
  #bcf-quote .secbody{ display:none; padding:0 22px 8px; }
  #bcf-quote .sec.open .secbody{ display:block; }

  /* item row */
  #bcf-quote .item{ display:flex; align-items:center; gap:14px; padding:13px 0; border-top:1px solid var(--line); }
  #bcf-quote .item:first-child{ border-top:0; }
  #bcf-quote .item .info{ flex:1; min-width:0; }
  #bcf-quote .item .iname{ font-size:15px; font-weight:600; color:var(--ink); line-height:1.25; }
  #bcf-quote .item .inote{ font-family:var(--mono); font-size:10.5px; color:var(--ink-faint); margin-top:3px; letter-spacing:.02em; }
  #bcf-quote .item.on .iname{ color:var(--sage-deep); }
  #bcf-quote .help{ display:inline-grid; place-items:center; width:15px; height:15px; border-radius:50%; border:1px solid var(--line-strong); background:var(--paper); color:var(--ink-faint); font-family:var(--mono); font-size:8.5px; font-weight:700; margin-left:7px; vertical-align:middle; position:relative; cursor:pointer; padding:0; }
  #bcf-quote .help:hover{ border-color:var(--rose); color:var(--rose); }
  #bcf-quote .help .pop{ display:none; position:absolute; bottom:150%; left:50%; transform:translateX(-50%); width:190px; padding:6px; background:var(--paper); border:1px solid var(--line); border-radius:12px; box-shadow:var(--shadow-md); z-index:40; }
  #bcf-quote .help .pop img{ width:100%; height:140px; object-fit:cover; border-radius:8px; display:block; }
  #bcf-quote .help .pop::after{ content:''; position:absolute; top:100%; left:50%; transform:translateX(-50%); border:7px solid transparent; border-top-color:var(--paper); }
  #bcf-quote .help:hover .pop, #bcf-quote .help.on .pop{ display:block; }

  /* stepper */
  #bcf-quote .step{ display:flex; align-items:center; border:1.5px solid var(--line-strong); border-radius:999px; overflow:hidden; flex-shrink:0; }
  #bcf-quote .step button{ width:32px; height:32px; border:0; background:var(--paper); color:var(--sage-deep); font-size:17px; display:grid; place-items:center; transition:background .14s; }
  #bcf-quote .step button:hover{ background:var(--sage-tint); }
  #bcf-quote .step button:disabled{ color:var(--line-strong); cursor:not-allowed; background:var(--paper); }
  #bcf-quote .step .qty{ width:30px; text-align:center; font-family:var(--mono); font-size:14px; font-weight:700; color:var(--ink); }
  #bcf-quote .item.on .step{ border-color:var(--rose); }

  /* palette (step 2) */
  #bcf-quote .palette{ display:none; }
  #bcf-quote.s2 .builder{ display:none; }
  #bcf-quote.s2 .palette{ display:block; }
  #bcf-quote .roleblock{ background:var(--paper); border:1px solid var(--line); border-radius:18px; margin-bottom:14px; padding:18px 22px 20px; box-shadow:var(--shadow-sm); }
  #bcf-quote .roleblock h3{ font-family:var(--serif); font-weight:600; font-size:18px; color:var(--ink); display:flex; align-items:center; gap:10px; }
  #bcf-quote .roleopt{ font-family:var(--mono); font-size:9.5px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--sage); background:var(--sage-tint); padding:3px 8px; border-radius:999px; }
  #bcf-quote .roleblock .rdesc{ font-size:13px; color:var(--ink-soft); margin-top:4px; line-height:1.45; }
  #bcf-quote .roleslots{ display:grid; gap:10px; margin-top:14px; }
  #bcf-quote .dupnote{ margin-top:10px; font-size:12.5px; line-height:1.45; color:var(--ink-soft); background:var(--cream-deep); border:1px solid var(--line-strong); border-radius:10px; padding:9px 12px; }
  #bcf-quote .dupnote .floret{ margin-right:3px; }
  #bcf-quote .pslot{ display:block; }
  @media (max-width:560px){ #bcf-quote .pslot .plabel{ margin-bottom:6px; } }
  #bcf-quote .vpick{ display:flex; align-items:center; gap:10px; width:100%; text-align:left; background:var(--cream); border:1.5px solid var(--line-strong); border-radius:10px; padding:8px 12px; cursor:pointer; transition:border-color .14s; }
  #bcf-quote .vpick:hover{ border-color:var(--rose); }
  #bcf-quote .vpick.ex{ border-style:dashed; }
  #bcf-quote .vpick.ex .vname{ color:var(--ink-faint); font-style:italic; }
  #bcf-quote .vthumb{ width:34px; height:34px; border-radius:8px; flex-shrink:0; background-size:cover; background-position:center; background-color:var(--sage-tint); border:1px solid var(--line); }
  #bcf-quote .vthumb.ph{ display:grid; place-items:center; }
  #bcf-quote .vthumb.ph::after{ content:'\2767'; color:var(--sage); font-size:15px; }
  #bcf-quote .vname{ flex:1; min-width:0; font-size:14.5px; font-weight:600; color:var(--ink); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  #bcf-quote .vchev{ color:var(--ink-faint); flex-shrink:0; display:flex; }
  #bcf-quote .vgal{ position:fixed; inset:0; z-index:120; background:rgba(20,28,20,.5); display:none; align-items:flex-end; justify-content:center; padding-top:var(--bcf-header-h,70px); }
  #bcf-quote .vgal.on{ display:flex; }
  #bcf-quote .vgal-card{ background:var(--cream); width:100%; max-width:640px; max-height:calc(100vh - var(--bcf-header-h,70px) - 20px); border-radius:20px 20px 0 0; display:flex; flex-direction:column; box-shadow:0 -10px 40px rgba(0,0,0,.3); }
  @media (min-width:600px){ #bcf-quote .vgal{ align-items:center; } #bcf-quote .vgal-card{ border-radius:20px; } }
  #bcf-quote .vgal-top{ display:flex; align-items:center; justify-content:space-between; padding:18px 20px 10px; }
  #bcf-quote .vgal-title{ font-family:var(--serif); font-weight:600; font-size:20px; color:var(--ink); }
  #bcf-quote .vgal-x{ border:0; background:transparent; font-size:26px; line-height:1; color:var(--ink-soft); cursor:pointer; padding:0 4px; }
  #bcfTailor .vgal-card{ background:#fff; }
  #bcfTailor .tlr-ck{ background:var(--cream); }
  #bcfTailor #tlrForm input, #bcfTailor #tlrForm select, #bcfTailor #tlrForm textarea{ background:var(--cream); border-color:var(--line); }
  #bcf-quote .vgal-search{ margin:0 20px 12px; font-family:var(--sans); font-size:14.5px; border:1.5px solid var(--line-strong); border-radius:10px; padding:11px 13px; }
  #bcf-quote .vgal-search:focus{ outline:none; border-color:var(--rose); }
  #bcf-quote .vgal-chips{ display:flex; flex-wrap:wrap; gap:6px; padding:2px 20px 14px; }
  #bcf-quote .vchip{ font-family:var(--mono); font-size:10px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--ink-soft); background:transparent; border:1.5px solid var(--line-strong); border-radius:999px; padding:6px 13px; cursor:pointer; transition:all .12s; }
  #bcf-quote .vchip:hover{ border-color:var(--sage); color:var(--sage-deep); }
  #bcf-quote .vchip.on{ background:var(--sage-deep); color:var(--cream); border-color:var(--sage-deep); }
  #bcf-quote .vgal-grid{ overflow-y:auto; padding:0 20px 22px; }
  #bcf-quote .vgal-gh{ font-family:var(--mono); font-size:10.5px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--sage); margin:16px 0 8px; }
  #bcf-quote .vgal-row{ display:grid; grid-template-columns:repeat(auto-fill,minmax(96px,1fr)); gap:10px; }
  #bcf-quote .vtile{ display:flex; flex-direction:column; gap:6px; border:1.5px solid var(--line); background:var(--paper); border-radius:12px; padding:8px; cursor:pointer; text-align:center; transition:border-color .14s, transform .12s; }
  #bcf-quote .vtile:hover{ border-color:var(--rose); transform:translateY(-2px); }
  #bcf-quote .vtile.on{ border-color:var(--rose); box-shadow:0 0 0 2px var(--rose-tint); }
  #bcf-quote .vtile-img{ width:100%; aspect-ratio:1/1; border-radius:8px; background-size:cover; background-position:center; background-color:var(--sage-tint); }
  #bcf-quote .vtile-img.ph{ display:grid; place-items:center; }
  #bcf-quote .vtile-img.ph::after{ content:'\2767'; color:var(--sage); font-size:22px; }
  #bcf-quote .vtile-name{ font-size:12px; font-weight:600; color:var(--ink); line-height:1.2; }
  #bcf-quote .vgal-empty{ text-align:center; color:var(--ink-faint); padding:30px; font-style:italic; }
  #bcf-quote .vgal-foot{ padding:14px 20px 18px; border-top:1px solid var(--line); font-size:12.5px; line-height:1.5; color:var(--ink-soft); text-align:center; }
  #bcf-quote .vgal-foot a{ color:var(--rose); font-weight:600; text-decoration:underline; text-underline-offset:2px; }
  #bcf-quote .tlr-body{ padding:0 20px 22px; overflow-y:auto; }
  #bcf-quote .tlr-lead{ font-size:14px; line-height:1.5; color:var(--ink-soft); margin-bottom:14px; }
  #bcf-quote #tlrForm{ display:flex; flex-direction:column; gap:10px; }
  #bcf-quote .tlr-grid{ display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  #bcf-quote .tlr-f{ display:flex; flex-direction:column; gap:4px; }
  #bcf-quote .tlr-f > span{ font-family:var(--mono); font-size:9.5px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--ink-faint); }
  #bcf-quote .tlr-needs{ display:flex; flex-direction:column; gap:6px; }
  #bcf-quote .tlr-needs.flash .tlr-needs-q{ color:var(--rose); }
  #bcf-quote .tlr-needs-q{ font-family:var(--mono); font-size:9.5px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--ink-faint); margin-bottom:2px; }
  #bcf-quote .tlr-ck{ display:flex; align-items:center; gap:10px; font-size:13.5px; color:var(--ink); cursor:pointer; line-height:1.3; background:var(--cream-deep); border:1.5px solid var(--line-strong); border-radius:10px; padding:11px 13px; transition:border-color .12s, background .12s; }
  #bcf-quote .tlr-ck:hover{ border-color:var(--sage); }
  #bcf-quote .tlr-ck:has(input:checked){ border-color:var(--rose); background:var(--rose-tint); }
  #bcf-quote #tlrForm .tlr-ck input{ width:auto; flex-shrink:0; margin:0; accent-color:var(--rose); transform:scale(1.15); }
  @media (max-width:520px){ #bcf-quote .tlr-grid{ grid-template-columns:1fr; } }
  #bcf-quote #tlrForm input, #bcf-quote #tlrForm select, #bcf-quote #tlrForm textarea{ font-family:var(--sans); font-size:14.5px; border:1.5px solid var(--line-strong); border-radius:10px; padding:11px 13px; width:100%; resize:vertical; color:var(--ink); background:#fff; }
  #bcf-quote #tlrForm input:focus, #bcf-quote #tlrForm select:focus, #bcf-quote #tlrForm textarea:focus{ outline:none; border-color:var(--rose); }
  #bcf-quote .tlr-send{ border:0; border-radius:999px; background:var(--rose); color:#fff; font-family:var(--mono); font-weight:700; font-size:13px; letter-spacing:.03em; padding:14px; cursor:pointer; }
  #bcf-quote .tlr-send:hover{ background:var(--rose-deep); }
  #bcf-quote .tlr-sum{ margin-top:14px; }
  #bcf-quote .tlr-sum summary{ cursor:pointer; font-family:var(--mono); font-weight:700; font-size:11px; letter-spacing:.06em; text-transform:uppercase; color:var(--sage); }
  #bcf-quote .tlr-sum pre{ white-space:pre-wrap; font-family:var(--sans); font-size:12.5px; line-height:1.5; color:var(--ink); background:var(--cream-deep); border-radius:10px; padding:12px; margin-top:8px; }
  #bcf-quote .tlr-okmsg{ text-align:center; padding:34px 22px 40px; display:flex; flex-direction:column; align-items:center; }
  #bcf-quote .tlr-oklogo{ width:46px; height:46px; object-fit:contain; margin-bottom:18px; opacity:.92; }
  #bcf-quote .tlr-okhead{ font-family:var(--serif); font-size:23px; color:var(--sage-deep); line-height:1.25; margin-bottom:10px; }
  #bcf-quote .tlr-oksub{ font-family:var(--sans); font-size:14.5px; color:var(--ink-soft); line-height:1.55; max-width:380px; }
  #bcf-quote .pslot .plabel{ font-family:var(--mono); font-size:11px; font-weight:700; letter-spacing:.07em; text-transform:uppercase; color:var(--sage-deep); display:flex; align-items:center; gap:6px; margin-bottom:7px; white-space:nowrap; }
  #bcf-quote select{ width:100%; font-family:var(--sans); font-size:14.5px; font-weight:500; color:var(--ink); background:var(--cream); border:1.5px solid var(--line-strong); border-radius:10px; padding:10px 34px 10px 12px; appearance:none; cursor:pointer;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%235d685a' stroke-width='2.4' stroke-linecap='round'><path d='m6 9 6 6 6-6'/></svg>"); background-repeat:no-repeat; background-position:right 12px center; }
  #bcf-quote select:focus{ outline:none; border-color:var(--rose); }

  /* recipes (step 3) */
  #bcf-quote .results{ display:none; }
  #bcf-quote.s3 .builder, #bcf-quote.s3 .palette{ display:none; }
  #bcf-quote.s3 .results{ display:block; }
