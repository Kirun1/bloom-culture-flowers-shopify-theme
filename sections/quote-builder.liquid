    if(alacarte.length){ lines.push(''); lines.push('EXTRA FLOWERS'); alacarte.forEach(function(a){ lines.push('   - '+a.bunches+' bunch'+(a.bunches>1?'es':'')+' '+a.name); }); }
    var demand={}, order=[];
    selectedPieces().forEach(function(p){ var mult=(p.mult||1)*p.qty; p.recipe.forEach(function(sl,i){ if(isOpt(sl) && removed[p.id]&&removed[p.id][i])return; var fl=slotFlower(p,i); var pr=prod(fl); if(!pr)return; var u=amounts[p.id][i]; var bu=sl[2]==='b'?u:u/pr.stems; if(!demand[fl]){demand[fl]={bu:0};order.push(fl);} demand[fl].bu+=bu*mult; }); (additions[p.id]||[]).forEach(function(a){ var pr=prod(a.name); if(!pr)return; var bu=a.unit==='b'?a.amt:a.amt/pr.stems; if(!demand[a.name]){demand[a.name]={bu:0};order.push(a.name);} demand[a.name].bu+=bu*mult; }); });
