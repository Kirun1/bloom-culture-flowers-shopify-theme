        "template--18864357179699__79cd86e2-c6a8-4319-a2cb-e5061935e3f0-16832551451ab5e110-1": {
          "type": "heading",
          "settings": {
            "title": "We’re Not Floral Snobs. ",
            "heading_font_size": "heading-large",
            "padding_bottom": 16,
            "heading_tag": "automatic"
          }
        },
        "template--18864357179699__79cd86e2-c6a8-4319-a2cb-e5061935e3f0-16832551451ab5e110-2": {
          "type": "text",
          "settings": {
            "text": "<p>We’re not here to judge your budget, your flower choices, or your vision. Whether you love classics, colors, neutrals, or something totally unexpected — you’re welcome here. Our team is made up of professional designers who know wedding flowers inside and out, and we’re here to guide, not gatekeep. Your flowers, your style, your way.</p>",
            "text_font_size": "body-medium",
            "padding_bottom": 16
          }
        }
