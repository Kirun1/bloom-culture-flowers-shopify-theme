        "code": "<style>\n:root{\n  --cream:#f7f6f0; --cream-deep:#eeece1; --paper:#fff;\n  --ink:#2c352a; --ink-soft:#5d685a; --ink-faint:#98a18f;\n  --line:#e6e3d6; --line-strong:#d6d2c3;\n  --sage:#384d39; --sage-deep:#2b3c2c; --sage-tint:#e7ece3;\n  --rose:#aa2138; --rose-deep:#8c1a2e; --rose-tint:#f5e2e4; --gold:#b3934f;\n  --serif:\"Cabin\",system-ui,sans-serif;\n  --sans:\"Montserrat\",system-ui,sans-serif;\n  --mono:\"Archivo\",system-ui,sans-serif;\n  --shadow-sm:0 1px 3px rgba(58,52,44,.06);\n  --shadow-md:0 6px 22px rgba(58,52,44,.09);\n  --shadow-lg:0 22px 60px rgba(58,52,44,.16);\n}\n\n#bcf-landing *{box-sizing:border-box;margin:0;padding:0;}\n#bcf-landing{scroll-behavior:smooth;}\n#bcf-landing{font-family:var(--sans);background:var(--cream);color:var(--ink);-webkit-font-smoothing:antialiased;line-height:1.6;}\n#bcf-landing h1, #bcf-landing h2, #bcf-landing h3, #bcf-landing h4{font-family:var(--serif);font-weight:600;line-height:1.08;letter-spacing:-.01em;}\n#bcf-landing .mono{font-family:var(--mono);text-transform:uppercase;letter-spacing:.15em;font-weight:600;}\n#bcf-landing a{color:inherit;}\n#bcf-landing .wrap{max-width:1080px;margin:0 auto;padding:0 28px;}\n#bcf-landing .spark{color:var(--rose);display:inline-flex;align-items:center;line-height:1;}\n#bcf-landing .dot{color:var(--ink-faint);opacity:.6;}\n#bcf-landing /* sticky bar */\n.bar{position:sticky;top:0;z-index:20;background:rgba(247,246,240,.9);backdrop-filter:blur(10px);border-bottom:1px solid var(--line);}\n#bcf-landing .bar .wrap{display:flex;align-items:center;gap:14px;padding:13px 28px;}\n#bcf-landing .bar img{width:34px;height:34px;object-fit:contain;}\n#bcf-landing .bar .name{font-family:var(--serif);font-size:18px;font-weight:600;}\n#bcf-landing .bar .sub{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--ink-faint);margin-top:3px;}\n#bcf-landing .bar .cta{margin-left:auto;}\n#bcf-landing .btn{display:inline-flex;align-items:center;gap:9px;border:none;cursor:poi