nsparent;border:1.6px solid rgba(255,255,255,.4);}\n#bcf-landing /* pricing */\n.price{background:var(--sage-deep);color:var(--cream);}\n#bcf-landing .price-card{background:var(--paper);color:var(--ink);border-radius:24px;padding:46px 42px;box-shadow:var(--shadow-lg);max-width:560px;margin:40px auto 0;text-align:center;}\n#bcf-landing .price-card .amt{font-family:var(--serif);font-size:64px;line-height:1;color:var(--sage-deep);margin:6px 0 4px;}\n#bcf-landing .price-card .amt span{font-size:26px;vertical-align:super;}\n#bcf-landing .price-card .free{display:inline-block;background:var(--rose-tint);color:var(--rose-deep);font-family:var(--mono);font-size:11px;padding:7px 14px;border-radius:999px;margin-bottom:26px;}\n#bcf-landing .price-card ul{list-style:none;text-align:left;max-width:360px;margin:0 auto 30px;display:flex;flex-direction:column;gap:12px;}\n#bcf-landing .price-card li{display:flex;gap:11px;align-items:flex-start;font-size:15px;}\n#bcf-landing .price-card li .ic{color:var(--sage);flex-shrink:0;margin-top:3px;}\n#bcf-landing .price-card .btn-solid{width:100%;justify-content:center;padding:16px;font-size:16px;}\n#bcf-landing .price-card .guarantee{font-size:12.5px;color:var(--ink-faint);margin-top:16px;}\n#bcf-landing /* faq */\n.faq-item{border-bottom:1px solid var(--line);padding:0;}\n#bcf-landing .faq-item summary{font-family:var(--serif);font-size:18px;padding:22px 0;display:flex;gap:10px;align-items:flex-start;cursor:pointer;list-style:none;}\n#bcf-landing .faq-item summary::-webkit-details-marker{display:none;}\n#bcf-landing .faq-item summary .spark{margin-top:0;}\n#bcf-landing .faq-item[open] summary{padding-bottom:8px;}\n#bcf-landing .faq-item p{font-size:15px;color:var(--ink-soft);padding-left:24px;padding-bottom:22px;margin:0;}\n#bcf-landing /* closing */\n.closing{background:var(--cream-deep);}\n#bcf-landing .closing .wrap{display:flex;align-items:flex-start;gap:44px;max-width:880px;}\n#bcf-landing .closing .founder-photo{width:200px;height:240px;flex-shrink:0;border-radius:18px;object-fit:cover;box-shadow:var(--shadow-md);background:var(--sage-tint);}\n#bcf-landing .closing .founder-text{text-align:left;}\n#bcf-landing .closing .note{font-family:var(--serif);font-style:italic;font-size:clamp(20px,2.4vw,26px);color:var(--sage-deep);margin:10px 0 16px;}\n#bcf-landing .closing .sig{font-family:var(--serif);font-style:italic;font-size:18px;color:var(--ink-soft);margin-bottom:24px;}\n@media(max-width:680px){\n#bcf-landing .closing .wrap{flex-direction:column;text-align:center;gap:24px;}\n#bcf-landing .closing .founder-text{text-align:center;}\n}\n#bcf-landing /* footer */\nfooter{background:var(--sage-deep);color:rgba(247,246,240,.7);text-align:center;padding:40px 28px;font-size:13px;}\n#bcf-landing footer .name{font-family:var(--serif);font-size:20px;color:var(--cream);margin-bottom:6px;}\n@media(max-width:760px){\n#bcf-landing .calm-grid{grid-template-columns:1fr;}\n#bcf-landing .tcards{grid-template-columns:1fr;}\n#bcf-landing .mods{grid-template-columns:1fr;}\n#bcf-landing .split{grid-template-columns:1fr;gap:34px;}\n#bcf-landing section{padding:44px 0;}\n}\n\n</style>\n<div id=\"bcf-landing\">\n\n<!-- alert banner (hidden by default) -->\n<div id=\"bcf-alert-banner\" style=\"display:none; background:var(--rose-tint); color:var(--rose-deep); border-bottom:1px solid #ebc6cc; padding:14px 28px; font-family:var(--sans); font-size:14.5px; text-align:center; font-weight:500; position:relative; z-index:100;\">\n   Access expired or unauthorized. Please purchase the planner or wedding flowers to unlock.\n</div>\n\n\n<!-- sticky bar -->\n<div class=\"bar\">\n  <div class=\"wrap\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0750/7984/4147/files/bcf_favicon.png?v=1765476178\" alt=\"Bloom Culture\" />\n    <div>\n      <div class=\"name\">Bloom Culture<sup style=\"font-size:.5em;font-weight:600;top:-.7em;\">TM</sup></div>\n      <div class=\"sub\">DIY WEDDING FLOWER PLANNER</div>\n    </div>\n    <a href=\"https://bloomcultureflowers.com/products/diy-wedding-flower-planner\" class=\"btn btn-solid cta\">Get the Planner</a>\n  </div>\n</div>\n\n<!-- hero -->\n<header class=\"hero\">\n  <div class=\"wrap\">\n    <div class=\"hcopy\">\n      <div class=\"mono kick\"><span class=\"spark\">✦</span> THE DIY WEDDING FLOWER PLANNER</div>\n      <h1>Do your own wedding flowers, <em>without the overwhelm.</em></h1>\n      <p>The only private, step-by-step planner made just for DIY wedding flowers. Interactive timelines, tutorials, worksheets, and checklists, all in one beautifully organized space.</p>\n      <div class=\"row\">\n        <a href=\"https://bloomcultureflowers.com/products/diy-wedding-flower-planner\" class=\"btn btn-cream\">Get instant access, $49 <span aria-hidden=\"true\">→</span></a>\n        <a href=\"https://bloomculture.myflodesk.com/planner-preview\" class=\"btn btn-ghost\">Try a free preview <span aria-hidden=\"true\">→</span></a>\n        <span class=\"note\">Free with any Bloom Culture flower order.</span>\n      </div>\n      <div class=\"tagstrip\">\n        <span>No wilted flowers</span><span class=\"spark\">✦</span>\n        <span>No stress</span><span class=\"spark\">✦</span>\n        <span>No surprises</span><span class=\"spark\">✦</span>\n        <span>Just beautiful blooms</span>\n      </div>\n    </div>\n    <div class=\"himg\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0750/7984/4147/files/insert_the_first_image_into_th_Nano_Banana_2_95354.webp?v=1780071000\" alt=\"The DIY Wedding Flower Planner shown on a tablet, styled with garden roses and eucalyptus\" loading=\"lazy\" />\n    </div>\n  </div>\n</header>\n\n<!-- reassurance -->\n<section class=\"calm\">\n  <div class=\"wrap\">\n    <div class=\"center\">\n      <div class=\"mono eyebrow\">BUILT FOR DIY SUCCESS</div>\n      <h2 class=\"lead center\">DIY flowers can feel overwhelming.\nThis makes them feel doable.</h2>\n      <p class=\"sub center\">Built on 20+ years in the floral industry and years of helping couples DIY their own weddings, all compiled in one calm, guided workspace so you always know exactly what to do next.</p>\n    </div>\n    <div class=\"calm-grid\">\n      <div class=\"calm-card\">\n        <div class=\"chead\"><div class=\"ic\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M8 7h11M8 12h11M8 17h11\"/><circle cx=\"4.2\" cy=\"7\" r=\"1.1\"/><circle cx=\"4.2\" cy=\"12\" r=\"1.1\"/><circle cx=\"4.2\" cy=\"17\" r=\"1.1\"/></svg></div><h3>Always know what's next</h3></div>\n        <p>A clear, do-this-now path from a few months out all the way to \"I do\", no guessing, no spiraling.</p>\n      </div>\n      <div class=\"calm-card\">\n        <div class=\"chead\"><div class=\"ic\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 4h14v12l-4 4H5z\"/><path d=\"M15 20v-4h4\"/><path d=\"M8 9h8M8 13h5\"/></svg></div><h3>Save as you go</h3></div>\n        <p>Notes, checklists, worksheets, and your wedding details all save automatically, pick up right where you left off.</p>\n      </div>\n      <div class=\"calm-card\">\n        <div class=\"chead\"><div class=\"ic\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M10 8.5l5 3.5-5 3.5z\"/></svg></div><h3>Arrange like a pro</h3></div>\n        <p>Step-by-step video tutorials for every piece, plus a mood board maker to lock in your vision, so you DIY with confidence.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- whats inside -->\n<section>\n  <div class=\"wrap\">\n    <div class=\"center\">\n      <div class=\"mono eyebrow\">EVERYTHING'S INSIDE</div>\n      <h2 