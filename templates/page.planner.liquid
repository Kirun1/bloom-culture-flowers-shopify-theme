<style>
:root{
  --cream:#f7f6f0; --cream-deep:#eeece1; --paper:#fff;
  --ink:#2c352a; --ink-soft:#5d685a; --ink-faint:#98a18f;
  --line:#e6e3d6; --line-strong:#d6d2c3;
  --sage:#384d39; --sage-deep:#2b3c2c; --sage-tint:#e7ece3;
  --rose:#aa2138; --rose-deep:#8c1a2e; --rose-tint:#f5e2e4; --gold:#b3934f;
  --serif:"Cabin",system-ui,sans-serif;
  --sans:"Montserrat",system-ui,sans-serif;
  --mono:"Archivo",system-ui,sans-serif;
  --shadow-sm:0 1px 3px rgba(58,52,44,.06);
  --shadow-md:0 6px 22px rgba(58,52,44,.09);
  --shadow-lg:0 22px 60px rgba(58,52,44,.16);
}

#bcf-landing *{box-sizing:border-box;margin:0;padding:0;}
#bcf-landing{scroll-behavior:smooth;}
#bcf-landing{font-family:var(--sans);background:var(--cream);color:var(--ink);-webkit-font-smoothing:antialiased;line-height:1.6;}
#bcf-landing h1, #bcf-landing h2, #bcf-landing h3, #bcf-landing h4{font-family:var(--serif);font-weight:600;line-height:1.08;letter-spacing:-.01em;}
#bcf-landing .mono{font-family:var(--mono);text-transform:uppercase;letter-spacing:.15em;font-weight:600;}
#bcf-landing a{color:inherit;}
#bcf-landing .wrap{max-width:1080px;margin:0 auto;padding:0 28px;}
#bcf-landing .spark{color:var(--rose);display:inline-flex;align-items:center;line-height:1;}
#bcf-landing .dot{color:var(--ink-faint);opacity:.6;}
#bcf-landing /* sticky bar */
.bar{position:sticky;top:0;z-index:20;background:rgba(247,246,240,.9);backdrop-filter:blur(10px);border-bottom:1px solid var(--line);}
#bcf-landing .bar .wrap{display:flex;align-items:center;gap:14px;padding:13px 28px;}
#bcf-landing .bar img{width:34px;height:34px;object-fit:contain;}
#bcf-landing .bar .name{font-family:var(--serif);font-size:18px;font-weight:600;}
#bcf-landing .bar .sub{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--ink-faint);margin-top:3px;}
#bcf-landing .bar .cta{margin-left:auto;}
#bcf-landing .btn{display:inline-flex;align-items:center;gap:9px;border:none;cursor:pointer;font-family:var(--sans);
  font-size:14.5px;font-weight:600;padding:13px 24px;border-radius:999px;text-decoration:none;transition:transform .15s,box-shadow .15s;}
#bcf-landing .btn:hover{transform:translateY(-1px);}
#bcf-landing .btn-solid{background:var(--sage-deep);color:var(--cream);box-shadow:var(--shadow-sm);}
#bcf-landing .btn-solid:hover{box-shadow:var(--shadow-md);}
#bcf-landing .btn-cream{background:var(--cream);color:var(--sage-deep);box-shadow:0 4px 14px rgba(0,0,0,.18);}
#bcf-landing .btn-ghost{background:transparent;color:var(--cream);border:1px solid rgba(255,255,255,.32);}
#bcf-landing .bar .btn{padding:10px 20px;font-size:13.5px;}
#bcf-landing /* hero */
.hero{background:var(--sage-deep);color:var(--cream);position:relative;overflow:hidden;}
#bcf-landing .hero .wrap{padding:78px 28px 84px;position:relative;display:grid;grid-template-columns:1.3fr .7fr;gap:48px;align-items:center;}
#bcf-landing .hero .hcopy{min-width:0;}
#bcf-landing .hero .himg{min-width:0;border-radius:20px;overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.28);aspect-ratio:4/5;}
#bcf-landing .hero .himg img{width:100%;height:100%;display:block;object-fit:cover;object-position:center 32%;transform:scale(1.35);}
#bcf-landing .hero .kick{color:var(--cream);opacity:.85;font-size:11px;margin-bottom:22px;display:inline-flex;align-items:center;gap:7px;}
#bcf-landing .hero h1{color:var(--cream);font-size:clamp(34px,4.4vw,58px);max-width:560px;margin-bottom:22px;}
#bcf-landing .hero h1 em{font-style:italic;color:#e9d6b8;}
#bcf-landing .hero p{font-size:clamp(16px,1.7vw,19px);color:rgba(247,246,240,.82);max-width:520px;margin-bottom:30px;}
#bcf-landing .hero .row{display:flex;flex-wrap:wrap;gap:14px;align-items:center;}
#bcf-landing .hero .note{font-size:13.5px;color:rgba(247,246,240,.7);}
@media(max-width:820px){
#bcf-landing .hero .wrap{grid-template-columns:1fr;gap:38px;}
#bcf-landing .hero .himg{max-width:460px;}
}
#bcf-landing .tagstrip{display:flex;flex-wrap:wrap;align-items:center;gap:6px 16px;margin-top:46px;font-family:var(--serif);font-style:italic;font-size:16px;color:rgba(247,246,240,.78);}
#bcf-landing .tagstrip .spark{font-style:normal;font-size:18px;font-family:Georgia,serif;}
#bcf-landing /* section scaffolding */
section{padding:60px 0;}
#bcf-landing .eyebrow{font-size:11px;color:var(--rose-deep);margin-bottom:14px;}
#bcf-landing .lead{font-size:clamp(26px,3.4vw,38px);max-width:680px;margin-bottom:18px;}
#bcf-landing .sub{font-size:17px;color:var(--ink-soft);max-width:600px;}
#bcf-landing .center{text-align:center;margin-left:auto;margin-right:auto;}
#bcf-landing /* reassurance band */
.calm{background:var(--cream-deep);}
#bcf-landing .calm-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:46px;}
#bcf-landing .calm-card{background:var(--paper);border:1px solid var(--line);border-radius:18px;padding:22px 24px;box-shadow:var(--shadow-sm);}
#bcf-landing .calm-card .chead{display:flex;align-items:center;gap:13px;margin-bottom:11px;}
#bcf-landing .calm-card .ic{width:38px;height:38px;border-radius:11px;background:var(--sage-tint);color:var(--sage-deep);display:grid;place-items:center;flex-shrink:0;}
#bcf-landing .calm-card h3{font-size:19px;margin:0;}
#bcf-landing .calm-card p{font-size:14.5px;color:var(--ink-soft);}
#bcf-landing .tcards{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:46px;}
#bcf-landing .tcard{background:var(--paper);border:1px solid var(--line);border-radius:18px;padding:28px 26px;box-shadow:var(--shadow-sm);margin:0;}
#bcf-landing .tcard .stars{color:var(--gold);font-size:15px;letter-spacing:2px;margin-bottom:14px;}
#bcf-landing .tcard blockquote{margin:0;padding:0;border:0;font-family:var(--serif);font-size:16.5px;line-height:1.5;color:var(--ink);font-style:italic;}
#bcf-landing /* modules grid */
.mods{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-top:46px;}
#bcf-landing .mod{display:flex;align-items:center;gap:16px;background:var(--paper);border:1px solid var(--line);border-radius:15px;padding:18px 20px;box-shadow:var(--shadow-sm);}
#bcf-landing .mod .ic{width:42px;height:42px;border-radius:11px;background:var(--sage-tint);color:var(--sage-deep);display:grid;place-items:center;flex-shrink:0;}
#bcf-landing .mod .n{font-family:var(--mono);font-size:10px;color:var(--ink-faint);margin-bottom:3px;}
#bcf-landing .mod h4{font-size:17px;}
#bcf-landing .mod .k{font-size:12.5px;color:var(--ink-soft);margin-top:2px;}
#bcf-landing /* feature split */
.split{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:center;}
#bcf-landing .feat-list{list-style:none;display:flex;flex-direction:column;gap:20px;margin-top:24px;}
#bcf-landing .feat-list li{display:flex;gap:14px;align-items:flex-start;}
#bcf-landing .feat-list .ic{width:34px;height:34px;border-radius:9px;background:var(--rose-tint);color:var(--rose-deep);display:grid;place-items:center;flex-shrink:0;}
#bcf-landing .feat-list h4{font-size:17px;margin-bottom:3px;}
#bcf-landing .feat-list p{font-size:14px;color:var(--ink-soft);}
#bcf-landing .mock{background:var(--sage-deep);border-radius:22px;padding:38px 36px;box-shadow:var(--shadow-lg);position:relative;overflow:hidden;}
#bcf-landing .mock .chip{display:inline-block;font-family:var(--mono);font-size:9px;color:var(--cream);background:rgba(255,255,255,.14);padding:6px 13px;border-radius:999px;margin-bottom:22px;letter-spacing:.12em;}
#bcf-landing .mock h3{color:var(--cream);font-size:26px;margin-bottom:10px;}
#bcf-landing .mock p{color:rgba(247,246,240,.8);font-size:14px;margin-bottom:20px;}
#bcf-landing .mock .ck{display:flex;align-items:center;gap:12px;padding:13px 0;border-top:1px solid rgba(255,255,255,.12);color:var(--cream);font-size:14px;}
#bcf-landing .mock .box{width:20px;height:20px;border-radius:6px;background:var(--cream);color:var(--sage-deep);display:grid;place-items:center;flex-shrink:0;}
#bcf-landing .mock .box.empty{background:transparent;border:1.6px solid rgba(255,255,255,.4);}
#bcf-landing /* pricing */
.price{background:var(--sage-deep);color:var(--cream);}
#bcf-landing .price-card{background:var(--paper);color:var(--ink);border-radius:24px;padding:46px 42px;box-shadow:var(--shadow-lg);max-width:560px;margin:40px auto 0;text-align:center;}
#bcf-landing .price-card .amt{font-family:var(--serif);font-size:64px;line-height:1;color:var(--sage-deep);margin:6px 0 4px;}
#bcf-landing .price-card .amt span{font-size:26px;vertical-align:super;}
#bcf-landing .price-card .free{display:inline-block;background:var(--rose-tint);color:var(--rose-deep);font-family:var(--mono);font-size:11px;padding:7px 14px;border-radius:999px;margin-bottom:26px;}
#bcf-landing .price-card ul{list-style:none;text-align:left;max-width:360px;margin:0 auto 30px;display:flex;flex-direction:column;gap:12px;}
#bcf-landing .price-card li{display:flex;gap:11px;align-items:flex-start;font-size:15px;}
#bcf-landing .price-card li .ic{color:var(--sage);flex-shrink:0;margin-top:3px;}
#bcf-landing .price-card .btn-solid{width:100%;justify-content:center;padding:16px;font-size:16px;}
#bcf-landing .price-card .guarantee{font-size:12.5px;color:var(--ink-faint);margin-top:16px;}
#bcf-landing /* faq */
.faq-item{border-bottom:1px solid var(--line);padding:0;}
#bcf-landing .faq-item summary{font-family:var(--serif);font-size:18px;padding:22px 0;display:flex;gap:10px;align-items:flex-start;cursor:pointer;list-style:none;}
#bcf-landing .faq-item summary::-webkit-details-marker{display:none;}
#bcf-landing .faq-item summary .spark{margin-top:0;}
#bcf-landing .faq-item[open] summary{padding-bottom:8px;}
#bcf-landing .faq-item p{font-size:15px;color:var(--ink-soft);padding-left:24px;padding-bottom:22px;margin:0;}
#bcf-landing /* closing */
.closing{background:var(--cream-deep);}
#bcf-landing .closing .wrap{display:flex;align-items:flex-start;gap:44px;max-width:880px;}
#bcf-landing .closing .founder-photo{width:200px;height:240px;flex-shrink:0;border-radius:18px;object-fit:cover;box-shadow:var(--shadow-md);background:var(--sage-tint);}
#bcf-landing .closing .founder-text{text-align:left;}
#bcf-landing .closing .note{font-family:var(--serif);font-style:italic;font-size:clamp(20px,2.4vw,26px);color:var(--sage-deep);margin:10px 0 16px;}
#bcf-landing .closing .sig{font-family:var(--serif);font-style:italic;font-size:18px;color:var(--ink-soft);margin-bottom:24px;}
@media(max-width:680px){
#bcf-landing .closing .wrap{flex-direction:column;text-align:center;gap:24px;}
#bcf-landing .closing .founder-text{text-align:center;}
}
#bcf-landing /* footer */
footer{background:var(--sage-deep);color:rgba(247,246,240,.7);text-align:center;padding:40px 28px;font-size:13px;}
#bcf-landing footer .name{font-family:var(--serif);font-size:20px;color:var(--cream);margin-bottom:6px;}
@media(max-width:760px){
#bcf-landing .calm-grid{grid-template-columns:1fr;}
#bcf-landing .tcards{grid-template-columns:1fr;}
#bcf-landing .mods{grid-template-columns:1fr;}
#bcf-landing .split{grid-template-columns:1fr;gap:34px;}
#bcf-landing section{padding:44px 0;}
}

