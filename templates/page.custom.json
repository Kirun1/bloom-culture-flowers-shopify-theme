    "2c49db44-4cb6-4530-9af5-51db410b5d08": {
      "type": "section-rich-text",
      "blocks": {
        "template--20315109818675__2c49db44-4cb6-4530-9af5-51db410b5d08-heading-1": {
          "type": "heading",
          "settings": {
            "title": "Custom Floral Package Options ",
            "heading_font_size": "heading-large",
            "padding_bottom": 16,
            "heading_tag": "automatic"
