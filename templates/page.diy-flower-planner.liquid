{% comment %}
  Shopify Liquid Template Gating Snippet for Bloom Culture DIY Flower Planner
{% endcomment %}

{% if customer %}
  {% comment %} Check for bypass tag first (staff, manual test accounts) {% endcomment %}
  {% assign has_access = false %}
  {% if customer.tags contains 'planner-bypass' %}
    {% assign has_access = true %}
  {% elsif customer.tags contains 'planner-access' %}
    {% comment %} Rolling 2-year window validation (2 years = 730 days = 63,072,000 seconds) {% endcomment %}
    {% assign two_years_ago_seconds = 'now' | date: '%s' | minus: 63072000 %}
    {% for order in customer.orders %}
      {% assign order_date_seconds = order.created_at | date: '%s' | plus: 0 %}
      {% if order.financial_status == 'paid' and order_date_seconds >= two_years_ago_seconds %}
        {% assign has_access = true %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% if has_access %}
    {% comment %} Authorized: Inject Supabase keys and customer ID dynamically {% endcomment %}
    <script>
      window.BC_CUSTOMER = {
        id: "{{ customer.id }}",
        email: "{{ customer.email }}"
      };
      // TODO: Add supabase project keys
      window.BC_SUPABASE_URL = "https://mvrcmtbvfvmigjloxcva.supabase.co";
      window.BC_SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im12cmNtdGJ2ZnZtaWdqbG94Y3ZhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA1MTMxMTMsImV4cCI6MjA5NjA4OTExM30.eJrX0esqVIXST_-xY5D-XYBF8fHQwYkbp_qylqlDEWg";
    </script>

    {% comment %} Load the Planner App Container {% endcomment %}
    <div id="planner-app-container">
      <iframe src="https://bloomcultureflowers.netlify.app/" 
              style="width: 100%; height: 100vh; border: none; overflow: hidden;"
              allow="clipboard-write"></iframe>
    </div>
  {% else %}
    {% comment %} Logged in but not authorized or access expired {% endcomment %}
    <script>
      window.location.href = "/pages/diy-wedding-flowers-planner";
    </script>
    <noscript>
      <p>Access expired or unauthorized. Please purchase the planner or wedding flowers to unlock. <a href="/pages/diy-wedding-flowers-planner">Click here to continue</a>.</p>
    </noscript>
  {% endif %}
{% else %}
  {% comment %} Not logged in: Redirect to login page and redirect back after login {% endcomment %}
  <script>
    window.location.href = "/account/login?checkout_url=" + encodeURIComponent(window.location.pathname);
  </script>
  <noscript>
    <p>Please <a href="/account/login">log in</a> to access your wedding flower planner.</p>
  </noscript>
{% endif %}
